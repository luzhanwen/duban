{
  "name": "duban",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "读伴 —— 浏览器端 AI 陪读应用（纯前端，BYOK）",
  "scripts": {
    "dev": "vite --mode test",
    "build": "vite build",
    "build:formal": "vite build --mode formal",
    "build:test": "vite build --mode test",
    "preview": "vite preview",
    "tauri": "node node_modules/@tauri-apps/cli/tauri.js",
    "tauri:dev": "npm run tauri -- dev",
    "tauri:build": "npm run tauri -- build --bundles app",
    "tauri:build:all": "npm run tauri -- build",
    "icons:generate": "npm run tauri -- icon public/logo.svg",
    "package:mac-local": "npm run tauri:build && ./scripts/build-local-dmg.sh",
    "security:audit": "npm audit && npm run security:rust-duplicates && npm run security:scan",
    "security:scan": "node scripts/security_scan.mjs",
    "security:rust-duplicates": "cd src-tauri && cargo tree -d"
  },
  "dependencies": {
    "@lingo-reader/mobi-parser": "^0.4.6",
    "@tauri-apps/api": "^2.11.1",
    "localforage": "^1.10.0",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
