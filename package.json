    "tauri:build:formal": "npm run tauri -- build --bundles app --config src-tauri/tauri.formal.conf.json",
    "tauri:build:test": "node scripts/build_test_desktop.mjs",
    "tauri:build:all": "npm run tauri -- build",
    "icons:generate": "npm run tauri -- icon public/logo.svg",
    "package:mac-local": "npm run tauri:build:formal && ./scripts/build-local-dmg.sh",
    "release:preflight": "npm run version:check && node scripts/release_preflight.mjs",
    "release:check": "node scripts/release_check.mjs",
    "release:prepare": "node scripts/release_prepare.mjs",
    "release:notes": "node scripts/release_notes.mjs",
    "release:self-test": "node scripts/test_release_workflow.mjs",
    "release:manifest": "node scripts/release_manifest.mjs",
    "release:publish": "node scripts/release_publish.mjs",
    "updater:manifest": "node scripts/updater_manifest.mjs",
    "updater:publish": "node scripts/updater_publish.mjs",
    "release:signing-preflight": "npm run version:check && node scripts/release_signing_preflight.mjs",
    "package:mac-signed": "./scripts/package-mac-signed.sh",
    "release:notarize": "./scripts/notarize-mac-dmg.sh",
    "release:gatekeeper": "./scripts/verify-mac-release.sh",
    "updater:preflight": "node scripts/updater_preflight.mjs",
    "version:check": "node scripts/version.mjs check",
    "version:set": "node scripts/version.mjs set",
    "version:bump": "node scripts/version.mjs bump",
